{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "edunic-teachers",
  "projectType": "application",
  "root": "apps/edunic-teachers",
  "sourceRoot": "apps/edunic-teachers/app",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["default", "^production", { "externalDependencies": ["next"] }],
      "outputs": [
        "{workspaceRoot}/apps/edunic-teachers/.next/!(cache)/**/*",
        "{workspaceRoot}/apps/edunic-teachers/.next/!(cache)"
      ],
      "options": {
        "cwd": "apps/edunic-teachers",
        "tty": false,
        "command": "next build"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "cwd": "apps/edunic-teachers",
        "command": "next dev"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": ["build"],
      "options": {
        "cwd": "apps/edunic-teachers",
        "command": "next start"
      }
    },
    "serve-static": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": ["build"],
      "options": {
        "cwd": "apps/edunic-teachers",
        "command": "next start"
      }
    },
    "build-deps": {
      "executor": "nx:noop",
      "dependsOn": ["^build"],
      "options": {}
    },
    "watch-deps": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": ["build-deps"],
      "options": {
        "command": "npx nx watch --projects edunic-teachers --includeDependentProjects -- npx nx build-deps edunic-teachers"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/eslint.config.mjs",
        "{workspaceRoot}/apps/edunic-teachers/eslint.config.mjs",
        "{workspaceRoot}/tools/eslint-rules/**/*",
        { "externalDependencies": ["eslint"] }
      ],
      "outputs": ["{options.outputFile}"],
      "options": {
        "cwd": "apps/edunic-teachers",
        "command": "eslint ."
      }
    }
  },
  "tags": []
}